# All live integrations are disabled by default.
GLYPH_ENABLE_LIVE_AI=false
GLYPH_ENABLE_LIVE_IMAGE_GENERATION=false
GLYPH_ENABLE_LIVE_BILLING=false
GLYPH_ENABLE_LIVE_DISTRIBUTION=false

# Local multi-report V1 persistence. Leave empty to use .glyph-data/.
GLYPH_DATA_DIR=
# Never enable this on a public deployment. Production must inject a durable
# QuestionQuotaGateway adapter instead of process-local counters.
GLYPH_ALLOW_VOLATILE_QUESTION_QUOTAS=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
OPENAI_MODEL_ILLUSTRATION=gpt-image-2

DATABASE_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
