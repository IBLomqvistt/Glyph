{
  "name": "glyph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --filter @glyph/worker build && pnpm --filter @glyph/web build",
    "dev": "pnpm --filter @glyph/web dev",
    "eval": "vitest run evals",
    "format:check": "prettier --check .",
    "generate:fixture": "node --import tsx fixtures/glyph-agent-swarm-demo/generate.ts",
    "lint": "pnpm --recursive --if-present lint",
    "pipeline:demo": "pnpm --filter @glyph/worker pipeline:demo",
    "setup:browsers": "playwright install chromium",
    "test": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit -p tsconfig.json && pnpm --recursive --if-present typecheck",
    "verify:architecture": "node --import tsx scripts/verify-architecture.ts",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm test:integration && pnpm eval && pnpm verify:architecture && pnpm build && pnpm test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.18.0",
    "@types/pg": "^8.15.5",
    "eslint": "^9.35.0",
    "eslint-config-next": "^16.2.0",
    "pdf-lib": "^1.17.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4"
  }
}
